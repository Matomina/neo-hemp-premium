# ── IMPORTANT ────────────────────────────────────────────────────────────────
# NEVER commit backend/.env to Git.
# Copy this file: copy .env.example .env  (Windows) / cp .env.example .env (Mac/Linux)
# Then fill in the values below.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# Docker local (see README.md for docker run command):
DATABASE_URL=postgresql://cbd:cbd_password@localhost:5432/culture_bio_diamant

# ── JWT ──────────────────────────────────────────────────────────────────────
# PRODUCTION: JWT_SECRET must be at least 32 random characters — never reuse dev value
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-in-production-min-32-chars-random
JWT_EXPIRES_IN=7d

# ── Admin seed ───────────────────────────────────────────────────────────────
# 1. Set ADMIN_EMAIL to the admin login email
# 2. Generate ADMIN_PASS_HASH with:
#    node -e "require('bcryptjs').hash('Admin1234!',12).then(console.log)"
# 3. Paste the hash below (starts with $2b$)
# Do NOT log or commit this hash.
ADMIN_EMAIL=admin@culturebiodiamant.fr
ADMIN_PASS_HASH=

# ── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_ORIGINS=http://localhost:5173

# ── SMTP (nodemailer) ────────────────────────────────────────────────────────
# Leave empty in development — emails are logged to console (SKIPPED_DEV mode)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Culture Bio Diamant <no-reply@culturebiodiamant.fr>
SMTP_SECURE=false

# ── Stripe (TEST mode only) ───────────────────────────────────────────────────
# IMPORTANT: STRIPE_ENABLED must remain false until CBD compliance is validated
# and an authorized Stripe account for CBD products is confirmed.
# Do NOT set STRIPE_ENABLED=true in local or production without this validation.
STRIPE_ENABLED=false
STRIPE_MODE=test
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost:5173/confirmation
STRIPE_CANCEL_URL=http://localhost:5173/panier

# ── PDF storage ───────────────────────────────────────────────────────────────
# Relative path from backend/ — backend/storage/ is git-ignored, never commit it
STORAGE_PATH=./storage
