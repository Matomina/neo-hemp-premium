NODE_ENV=development
PORT=4000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/culture_bio_diamant?schema=public

JWT_SECRET=replace-with-a-long-random-secret-min-32-chars
JWT_EXPIRES_IN=7d

ADMIN_EMAIL=admin@culturebiodiamant.fr
ADMIN_PASS_HASH=replace-with-bcrypt-hash

FRONTEND_ORIGINS=http://localhost:5173

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Culture Bio Diamant <contact@culturebiodiamant.fr>"
SMTP_SECURE=false

STRIPE_ENABLED=false
STRIPE_MODE=test
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost:5173/confirmation
STRIPE_CANCEL_URL=http://localhost:5173/panier

STORAGE_PATH=./storage
