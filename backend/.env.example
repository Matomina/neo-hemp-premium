# ── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/culture_bio_diamant

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_me_with_a_long_random_secret_minimum_32_chars
JWT_EXPIRES_IN=7d

# ── Admin seed ───────────────────────────────────────────────────────────────
# Generate bcrypt hash: node -e "require('bcryptjs').hash('your_password',12).then(console.log)"
ADMIN_EMAIL=admin@example.com
ADMIN_PASS_HASH=replace_me_with_bcrypt_hash

# ── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_ORIGINS=http://localhost:5173

# ── SMTP (nodemailer) ────────────────────────────────────────────────────────
# Leave empty in dev — emails logged to console (SKIPPED_DEV mode)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Culture Bio Diamant <no-reply@culturebiodiamant.fr>
SMTP_SECURE=false

# ── Stripe (TEST mode only) ───────────────────────────────────────────────────
# IMPORTANT: Do NOT set STRIPE_ENABLED=true in production without CBD
# compliance validation and an authorized Stripe account for CBD products.
STRIPE_ENABLED=false
STRIPE_MODE=test
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_SUCCESS_URL=http://localhost:5173/confirmation
STRIPE_CANCEL_URL=http://localhost:5173/panier

# ── PDF storage ───────────────────────────────────────────────────────────────
# Relative path from backend/ — never commit backend/storage (in .gitignore)
STORAGE_PATH=./storage
