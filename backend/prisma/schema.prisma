generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ──────────────────────────────────────────────────────────────────

enum ProductCategory {
  FLEURS
  RESINES
  COSMETIQUES
  ACCESSOIRES
  CONCENTRES
  HUILES
  ELIQUIDES
  PACKS
  ANIMAUX
}

enum LaunchStatus {
  ACTIVE
  COMING_SOON
  COMPLIANCE_REVIEW
  DISABLED
}

enum CertificateStatus {
  PENDING
  VALIDATED
  EXPIRED
  REJECTED
}

enum UserRole {
  CUSTOMER
  ADMIN
  SUPER_ADMIN
  SUPPORT
}

enum QuoteStatus {
  NEW
  REVIEWED
  APPROVED
  PAYMENT_SENT
  PAID
  CANCELLED
  EXPIRED
}

enum OrderStatus {
  CART_SUBMITTED
  PENDING_ADMIN_REVIEW
  APPROVED
  PAYMENT_SENT
  PAID
  CANCELLED
  REFUNDED
  EXPIRED
  // Legacy values kept for backward compat
  DRAFT
  PENDING
  CONFIRMED
}

enum InvoiceType {
  QUOTE
  ORDER
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  CANCELLED
}

enum PaymentProvider {
  STRIPE
}

enum PaymentType {
  QUOTE
  ORDER
}

enum PaymentStatusEnum {
  CREATED
  PENDING
  PAID
  FAILED
  CANCELLED
  EXPIRED
}

enum EmailStatus {
  QUEUED
  SENT
  FAILED
  SKIPPED_DEV
}

enum ContactStatus {
  NEW
  READ
  ARCHIVED
}

// ─── MODELS ─────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  firstName    String?
  lastName     String?
  name         String?
  role         UserRole @default(CUSTOMER)
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  addresses Address[]
  orders    Order[]
  auditLogs AuditLog[]
}

model Address {
  id           String   @id @default(cuid())
  userId       String?
  firstName    String
  lastName     String
  phone        String?
  addressLine1 String
  addressLine2 String?
  postalCode   String
  city         String
  country      String   @default("FR")
  createdAt    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

model Customer {
  id              String   @id @default(cuid())
  email           String   @unique
  firstName       String?
  lastName        String?
  phone           String?
  billingAddress  Json?
  shippingAddress Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  orders        Order[]
  quoteRequests QuoteRequest[]
  invoices      Invoice[]
}

model Product {
  id                       String          @id @default(cuid())
  slug                     String          @unique
  name                     String
  category                 ProductCategory
  shortDescription         String
  description              String
  priceCents               Int
  oldPriceCents            Int?
  cbdRate                  String?
  thcRate                  String?
  origin                   String?
  lot                      String?
  stock                    Int             @default(0)
  imageUrl                 String?
  isActive                 Boolean         @default(false)
  isFeatured               Boolean         @default(false)
  isBestSeller             Boolean         @default(false)
  certificateAvailable     Boolean         @default(false)
  requiresComplianceReview Boolean         @default(true)
  isSellable               Boolean         @default(false)
  launchStatus             LaunchStatus    @default(COMPLIANCE_REVIEW)
  complianceWarning        String?
  popularityScore          Int             @default(0)
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  certificates Certificate[]
  orderItems   OrderItem[]
}

model Certificate {
  id        String            @id @default(cuid())
  productId String?
  lot       String
  fileUrl   String
  labName   String?
  testedAt  DateTime?
  thcRate   String?
  cbdRate   String?
  status    CertificateStatus @default(PENDING)
  createdAt DateTime          @default(now())

  product Product? @relation(fields: [productId], references: [id])
}

model QuoteRequest {
  id               String      @id @default(cuid())
  publicRef        String      @unique
  status           QuoteStatus @default(NEW)
  customerId       String?
  customerSnapshot Json
  simulatorPayload Json?
  items            Json
  subtotalCents    Int
  taxCents         Int         @default(0)
  shippingCents    Int         @default(0)
  totalCents       Int
  currency         String      @default("EUR")
  adminNotes       String?
  clientMessage    String?
  approvedAt       DateTime?
  paymentSentAt    DateTime?
  paidAt           DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  customer Customer?  @relation(fields: [customerId], references: [id])
  invoices Invoice[]
  payments Payment[]
  emails   EmailLog[]
}

model Order {
  id               String      @id @default(cuid())
  publicRef        String      @unique @default(cuid())
  // Legacy field kept for backward compat
  orderNumber      String?     @unique
  customerId       String?
  userId           String?
  customerEmail    String
  customerName     String
  customerPhone    String?
  customerSnapshot Json?
  status           OrderStatus @default(CART_SUBMITTED)
  items            Json?
  subtotalCents    Int         @default(0)
  taxCents         Int         @default(0)
  shippingCents    Int         @default(0)
  totalCents       Int
  currency         String      @default("EUR")
  adminNotes       String?
  adultConfirmed   Boolean     @default(false)
  termsAccepted    Boolean     @default(false)
  note             String?
  approvedAt       DateTime?
  paymentSentAt    DateTime?
  paidAt           DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  customer  Customer?   @relation(fields: [customerId], references: [id])
  user      User?       @relation(fields: [userId], references: [id])
  orderItems OrderItem[]
  invoices  Invoice[]
  payments  Payment[]
  emails    EmailLog[]
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  productId  String?
  name       String
  quantity   Int
  unitCents  Int
  totalCents Int

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  type          InvoiceType
  quoteId       String?
  orderId       String?
  customerId    String?
  status        InvoiceStatus @default(DRAFT)
  pdfUrl        String?
  pdfPath       String?
  amountCents   Int
  currency      String        @default("EUR")
  issuedAt      DateTime?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  quote    QuoteRequest? @relation(fields: [quoteId], references: [id])
  order    Order?        @relation(fields: [orderId], references: [id])
  customer Customer?     @relation(fields: [customerId], references: [id])
  payments Payment[]
}

model Payment {
  id                       String            @id @default(cuid())
  type                     PaymentType
  quoteId                  String?
  orderId                  String?
  invoiceId                String?
  provider                 PaymentProvider   @default(STRIPE)
  stripeCheckoutSessionId  String?           @unique
  stripePaymentIntentId    String?
  status                   PaymentStatusEnum @default(CREATED)
  checkoutUrl              String?
  amountCents              Int
  currency                 String            @default("EUR")
  idempotencyKey           String?           @unique
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt

  quote   QuoteRequest? @relation(fields: [quoteId], references: [id])
  order   Order?        @relation(fields: [orderId], references: [id])
  invoice Invoice?      @relation(fields: [invoiceId], references: [id])
}

model EmailLog {
  id                String      @id @default(cuid())
  type              String
  to                String
  subject           String
  status            EmailStatus @default(QUEUED)
  providerMessageId String?
  payload           Json?
  error             String?
  quoteId           String?
  orderId           String?
  createdAt         DateTime    @default(now())

  quote QuoteRequest? @relation(fields: [quoteId], references: [id])
  order Order?        @relation(fields: [orderId], references: [id])
}

model ContactMessage {
  id         String        @id @default(cuid())
  name       String
  email      String
  phone      String?
  subject    String?
  message    String
  status     ContactStatus @default(NEW)
  adminNotes String?
  isRead     Boolean       @default(false)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model NewsletterSubscription {
  id        String   @id @default(cuid())
  email     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String?
  entityId   String?
  entity     String?
  metadata   Json?
  createdAt  DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id])
}

model BusinessSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
